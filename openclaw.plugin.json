{
  "id": "openclaw-dida365-mcp",
  "name": "滴答清单（Dida365）MCP",
  "description": "将滴答清单（Dida365）官方 MCP 工具通过 mcp-remote 暴露给 OpenClaw Agent。工具为 optional；若启用 tools.profile 或 allowlist，还需放行 group:plugins 或本插件。",
  "version": "0.2.2",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverUrl": {
        "type": "string",
        "default": "https://mcp.dida365.com"
      },
      "command": {
        "type": "string",
        "default": "npx"
      },
      "args": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "-y",
          "mcp-remote@latest"
        ]
      },
      "host": {
        "type": "string",
        "default": "127.0.0.1"
      },
      "authTimeoutSeconds": {
        "type": "integer",
        "minimum": 30,
        "default": 300
      },
      "requestTimeoutSeconds": {
        "type": "integer",
        "minimum": 60,
        "default": 300
      },
      "toolAllowlist": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "toolDenylist": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "idleTimeoutSeconds": {
        "type": "integer",
        "minimum": 0,
        "default": 600
      },
      "refreshManifestOnStartup": {
        "type": "boolean",
        "default": false
      },
      "manifestPath": {
        "type": "string"
      }
    }
  }
}
