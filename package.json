{
  "name": "@jacob2826/openclaw-dida365-mcp",
  "version": "0.2.2",
  "description": "OpenClaw plugin that exposes official Dida365 MCP tools through mcp-remote.",
  "type": "module",
  "license": "GPL-3.0-only",
  "keywords": [
    "openclaw",
    "mcp",
    "dida365",
    "ticktick",
    "openclaw-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob2826/openclaw-dida365-mcp.git"
  },
  "homepage": "https://github.com/jacob2826/openclaw-dida365-mcp#readme",
  "bugs": {
    "url": "https://github.com/jacob2826/openclaw-dida365-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "data",
    "dist",
    "openclaw.plugin.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test ./test/*.test.mjs",
    "ci": "npm run check && npm test",
    "prepack": "npm run ci",
    "list-tools": "node -e \"const m=require('./data/mcp-tools.json'); console.log(m.tools.map((tool)=>tool.name).join('\\n')); console.log('COUNT='+m.tools.length);\"",
    "scan-sensitive": "node ./scripts/scan-sensitive.mjs .",
    "refresh-tools": "node ./scripts/refresh-tools.mjs",
    "verify-basic": "node ./scripts/verify-basic.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@jacob2826/openclaw-dida365-mcp",
      "localPath": "extensions/openclaw-dida365-mcp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
